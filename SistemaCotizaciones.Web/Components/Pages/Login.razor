@page "/login"
@attribute [AllowAnonymous]
@layout SistemaCotizaciones.Web.Components.Layout.LoginLayout

<PageTitle>JAH - Login</PageTitle>

<section class="login-shell">
    <div class="login-brand">
        <img src="img/logo-jah.png" alt="JAH Mantencion" class="login-logo" />
        <MudText Typo="Typo.h3">JAH Cotizaciones</MudText>
        <MudText Typo="Typo.body1" Color="Color.Secondary">Sistema comercial para clientes, cotizaciones y aprobaciones.</MudText>
    </div>

    <MudPaper Class="login-card" Elevation="0">
        <MudText Typo="Typo.h5">Iniciar sesion</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">Ingresa con tu usuario empresarial.</MudText>

        @if (Error == "1")
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-3">
                Usuario o clave incorrectos.
            </MudAlert>
        }

        <form method="post" action="/auth/login">
            <input type="hidden" name="returnUrl" value="@ReturnUrl" />

            <label class="form-label" for="usuario">Email o usuario</label>
            <input id="usuario" class="login-input" type="text" name="usuario" autocomplete="username" required />

            <label class="form-label mt-3" for="password">Clave</label>
            <input id="password" class="login-input" type="password" name="password" required />

            <label class="remember-row">
                <input type="checkbox" name="recordar" />
                <span>Recordar sesion</span>
            </label>

            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Size="Size.Large">
                Entrar
            </MudButton>
        </form>

        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-4 d-block">
            Usuario inicial: admin@jahmantencion.cl
        </MudText>
    </MudPaper>
</section>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; } = "/";
}
