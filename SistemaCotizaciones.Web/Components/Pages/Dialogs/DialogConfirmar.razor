@using MudBlazor

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.h6">@Titulo</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">@Mensaje</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar">Cancelar</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="Confirmar">@TextoConfirmar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public string Titulo { get; set; } = "Confirmar";
    [Parameter] public string Mensaje { get; set; } = string.Empty;
    [Parameter] public string TextoConfirmar { get; set; } = "Confirmar";

    private void Cancelar() => MudDialog.Cancel();
    private void Confirmar() => MudDialog.Close(DialogResult.Ok(true));
}
